# Example environment template. Copy this file to `.env` and fill values.
# DO NOT commit your real `.env` to version control.

# MySQL
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=adtech_mysql
MYSQL_PORT=3306
MYSQL_DATABASE=adtech_db

# MongoDB
MONGO_USER=
MONGO_PASSWORD=
MONGO_HOST=adtech_mongo
MONGO_PORT=27017
MONGO_DB=adtech_nosql
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
MONGO_URI=

# Redis
REDIS_HOST=adtech_redis
REDIS_PORT=6379

# Tunables
SESSION_TIMEOUT_SECONDS=1800
USER_BATCH_SIZE=500
BULK_WRITE_BATCH_SIZE=1000

# ETL data paths (adjust to the actual location of your CSV files)
DATA_USERS_PATH=./data/users.csv
DATA_CAMPAIGNS_PATH=./data/campaigns.csv
DATA_EVENTS_PATH=./data/ad_events_header_updated.csv
